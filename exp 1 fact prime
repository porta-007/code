	ii)To display first 50 prime numbers.

	class Prime {
		public static void main(String[] args) {
			int start = 1, end = 50, count;
			for (int i = start; i <= end; i++) {
				count = 0;
				for (int j = 1; j <= end; j++) {
					if (i % j == 0) {
						count++;
					}
				}
				if (count == 2) {
					System.out.print(i + " ");
				}
			}
		}
	}
